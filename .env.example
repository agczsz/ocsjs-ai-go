# 服务运行配置
HOST=127.0.0.1
PORT=5000
DEBUG=true

# AI 接口配置 (OpenAI 兼容接口)
# 请在下方填入您的 API 密钥、接口地址和模型名称。
# 示例一：使用 DeepSeek 官方 API
# OPENAI_API_BASE=https://api.deepseek.com/v1
# OPENAI_API_KEY=your_api_key
# OPENAI_MODEL=deepseek-chat

# 示例二：使用 OpenAI 官方 API (需要代理配置)
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_API_KEY=your_api_key
# OPENAI_MODEL=gpt-3.5-turbo

# 示例三：使用本地 Ollama (完全免费且本地运行)
# OPENAI_API_BASE=http://127.0.0.1:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL=llama3

# 网络代理设置 (如需代理访问 API)
# PROXY=socks5://127.0.0.1:7890

# 缓存配置
ENABLE_CACHE=true
CACHE_EXPIRATION=86400

# 安全访问令牌 (留空则不开启访问限制)
ACCESS_TOKEN=

# 其他 AI 参数
MAX_TOKENS=500
TEMPERATURE=0.7
LOG_LEVEL=INFO

# 多模型模式 (standard, confidence, fallback)
MULTI_MODEL_MODE=standard

# 置信度阈值 (confidence 模式用)
CONFIDENCE_THRESHOLD=0.7

# Exa 联网搜索 API (可选，confidence 模式下使用)
# EXA_API_KEY=
# EXA_BASE_URL=https://api.exa.ai

# Fallback 模式备选模型 (可选)
# API_BASE1=
# API_KEY1=
# MODEL1=
# API_BASE2=
# API_KEY2=
# MODEL2=
# API_BASE3=
# API_KEY3=
# MODEL3=
